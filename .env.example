# Copy to .env and adjust. Every deploy-specific value lives here —
# brand, map center, hosts — never as code literals (docs/DESIGN.md §2).

SECRET_KEY=change-me
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# Outside compose, point at your own Postgres+PostGIS:
# DATABASE_URL=postgis://pleasefix:pleasefix@localhost:5432/pleasefix
# REDIS_URL=redis://localhost:6379/0

POSTGRES_PASSWORD=pleasefix

# Object storage (leave unset to store photos on local disk in dev).
# In compose, the public endpoint is the Caddy route, not the container:
# S3_ENDPOINT_URL=http://s3.localhost
S3_ACCESS_KEY=pleasefix
S3_SECRET_KEY=pleasefix-dev-secret
S3_BUCKET=pleasefix

# Reddit URL-import (optional): Reddit 403s unauthenticated server
# fetches from many networks. Create a free "script" app at
# https://www.reddit.com/prefs/apps and fill these in.
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=

SITE_NAME=PleaseFix
MAP_CENTER_LAT=3.1390
MAP_CENTER_LON=101.6869
MAP_DEFAULT_ZOOM=12
LANGUAGE_CODE=en
TIME_ZONE=Asia/Kuala_Lumpur

# macOS local dev (Homebrew):
# GDAL_LIBRARY_PATH=/opt/homebrew/lib/libgdal.dylib
# GEOS_LIBRARY_PATH=/opt/homebrew/lib/libgeos_c.dylib
