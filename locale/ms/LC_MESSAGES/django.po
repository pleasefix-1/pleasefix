msgid "Issues"
msgstr "Isu"

#: templates/base.html:60
msgid "API"
msgstr "API"

#: templates/base.html:73
msgid "An independent, open civic platform."
msgstr "Platform sivik bebas dan terbuka."

#: templates/base.html:74
msgid "Source code"
