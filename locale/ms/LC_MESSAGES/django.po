#: core/importers.py:192
msgid ""
"Reddit blocks unauthenticated fetches from this server. The site admin can "
"enable Reddit imports by setting REDDIT_CLIENT_ID/REDDIT_CLIENT_SECRET — or "
"copy the post details into the form manually."
msgstr ""
"Reddit menyekat pengambilan tanpa pengesahan daripada pelayan ini. Pentadbir "
"laman boleh mengaktifkan import Reddit dengan menetapkan REDDIT_CLIENT_ID/"
"REDDIT_CLIENT_SECRET — atau salin butiran kiriman ke dalam borang secara "
"manual."

#: core/importers.py:222
msgid "X/Twitter previews don't include photos — attach one if you have it."
msgstr ""
"Pratonton X/Twitter tidak menyertakan gambar — lampirkan satu jika ada."

#: core/importers.py:237
msgid ""
"That page didn't expose a public preview (it may require login) — please "
"fill in the details yourself."
msgstr ""
"Halaman itu tidak mendedahkan pratonton awam (mungkin memerlukan log masuk) "
"— sila isi butirannya sendiri."

#: core/importers.py:256
msgid "Could not read that link — try filling the form manually."
msgstr "Tidak dapat membaca pautan itu — cuba isi borang secara manual."

