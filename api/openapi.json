  "info": {
    "description": "Public API for the PleaseFix civic issue tracker. New here? The interactive developer walkthrough at /site/dev.html explains the architecture and data model; contributing starts at https://github.com/pleasefix-1/pleasefix/blob/main/CONTRIBUTING.md",
    "title": "PleaseFix API",
    "version": "1.0.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/v1/issues": {
      "get": {
        "operationId": "api_v1_list_issues",
        "parameters": [],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/IssueOut"
                  },
                  "title": "Response",
                  "type": "array"
                }
              }
            },
            "description": "OK"
          }
        },
        "summary": "List issues (newest first)"
      },
      "post": {
        "operationId": "api_v1_create_issue",
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IssueCreateIn"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IssueCreateOut"
                }
              }
            },
            "description": "Created"
          }
        },
        "summary": "Report a new issue"
      }
    },
    "/api/v1/issues/{issue_id}": {
      "get": {
        "operationId": "api_v1_get_issue",
        "parameters": [
          {
            "in": "path",
            "name": "issue_id",
            "required": true,
            "schema": {
              "title": "Issue Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IssueOut"
                }
              }
            },
            "description": "OK"
          }
        },
        "summary": "Get one issue by its public ID"
      }
    },
    "/api/v1/version": {
      "get": {
        "operationId": "api_v1_version",
        "parameters": [],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VersionOut"
                }
              }
            },
            "description": "OK"
          }
        },
        "summary": "API name and version"
      }
    }
  },
  "servers": []
}
