  "info": {
    "description": "Public API for the PleaseFix civic issue tracker.",
    "title": "PleaseFix API",
    "version": "1.0.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/v1/issues": {
      "get": {
        "operationId": "api_v1_list_issues",
        "parameters": [],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/IssueOut"
                  },
                  "title": "Response",
                  "type": "array"
                }
              }
            },
            "description": "OK"
          }
        },
        "summary": "List issues (newest first)"
      }
    },
    "/api/v1/issues/{issue_id}": {
      "get": {
        "operationId": "api_v1_get_issue",
        "parameters": [
          {
            "in": "path",
            "name": "issue_id",
            "required": true,
            "schema": {
              "title": "Issue Id",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IssueOut"
                }
              }
            },
            "description": "OK"
          }
        },
        "summary": "Get one issue"
      }
    },
    "/api/v1/version": {
      "get": {
        "operationId": "api_v1_version",
        "parameters": [],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VersionOut"
                }
              }
            },
            "description": "OK"
          }
        },
        "summary": "API name and version"
      }
    }
  },
  "servers": []
