{
  "name": "PleaseFix",
  "dockerComposeFile": ["../compose.yaml", "../compose.override.yaml"],
  "service": "app",
  "workspaceFolder": "/app",
  // The app image is the production image and stays git-free; features
  // are layered onto the dev container only.
  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": { "label": "PleaseFix app" }
  },
  "postCreateCommand": "test -f .env || cp .env.example .env; uv sync && uv run python manage.py compilemessages",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.mypy-type-checker",
        "charliermarsh.ruff"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/app/.venv/bin/python",
        "editor.formatOnSave": true,
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff"
        }
      }
    }
  }
}
